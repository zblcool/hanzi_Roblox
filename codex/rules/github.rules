prefix_rule(
    pattern = ["./scripts/gh-bot", ["issue", "api", "auth"]],
    decision = "allow",
    justification = "Use the Roblox migration workspace bot wrapper for GitHub operations.",
    match = [
        "./scripts/gh-bot issue list --repo zblcool/gameDev --state open --limit 1",
        "./scripts/gh-bot api graphql -f query=query",
        "./scripts/gh-bot auth status",
    ],
    not_match = [
        "./.tools/gh/bin/gh issue list --repo zblcool/gameDev --state open --limit 1",
        "gh issue list --repo zblcool/gameDev --state open --limit 1",
    ],
)

prefix_rule(
    pattern = ["./.tools/gh/bin/gh", ["issue", "api", "auth"]],
    decision = "forbidden",
    justification = "Use `./scripts/gh-bot` so Roblox migration GitHub operations use the bot account and the stable wrapper path.",
    match = [
        "./.tools/gh/bin/gh issue list --repo zblcool/gameDev --state open --limit 1",
        "./.tools/gh/bin/gh api graphql -f query=query",
        "./.tools/gh/bin/gh auth status",
    ],
)

prefix_rule(
    pattern = ["gh", ["issue", "api", "auth"]],
    decision = "forbidden",
    justification = "Use `./scripts/gh-bot` instead of bare `gh` in this Roblox migration workspace.",
    match = [
        "gh issue list --repo zblcool/gameDev --state open --limit 1",
        "gh api graphql -f query=query",
        "gh auth status",
    ],
)
